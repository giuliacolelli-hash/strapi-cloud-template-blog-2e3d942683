    "cognome": {
      "type": "string"
    },
    "email": {
      "type": "email",
      "required": true
    },
    "messaggio": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      },
      "required": true
    }
  }
}
