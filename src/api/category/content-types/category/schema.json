{
  "kind": "collectionType",
  "collectionName": "categories",
  "info": {
    "singularName": "category",
    "pluralName": "categories",
    "displayName": "Category",
    "description": "Organize your content into categories"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "slug": {
      "type": "uid"
    },
    "hero": {
      "type": "component",
      "component": "templates.hero-section",
      "repeatable": false
    },
    "articles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::article.article",
      "mappedBy": "category"
    },
    "projects": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::project.project",
      "mappedBy": "category"
    },
    "description": {
      "type": "component",
      "component": "basic.text",
      "repeatable": false
    },
    "Navigation": {
      "type": "component",
      "component": "basic.link-button",
      "repeatable": true
    }
  }
}
