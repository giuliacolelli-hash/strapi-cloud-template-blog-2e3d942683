{
  "collectionName": "components_prova_project_overviews",
  "info": {
    "displayName": "Project overview",
    "icon": "play"
  },
  "options": {},
  "attributes": {
    "projTitle": {
      "type": "string",
      "required": true
    },
    "projBlurb": {
      "type": "text",
      "required": true
    },
    "projImg": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "project": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::project.project"
    },
    "categoryLink": {
      "type": "component",
      "component": "prova.button",
      "repeatable": false
    },
    "projectLink": {
      "type": "component",
      "component": "prova.button",
      "repeatable": false
    }
  },
  "config": {}
}
